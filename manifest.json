{
  "manifest_version": 3,
  "name": "NYTimesNoAutoplay",
  "version": "1.1.0",
  "description": "Stop video and carousel autoplay on NYTimes.com.",
  "browser_specific_settings": {
    "gecko": {
      "id": "nytimesnoautoplay@nunus.extension",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "48": "icons/letterNu48.png",
    "96": "icons/letterNu96.png"
  },
  "host_permissions": [
    "https://www.nytimes.com/",
    "https://www.nytimes.com/?*",
    "https://nytimes.com/",
    "https://nytimes.com/?*",
    "https://*.nytimes.com/",
    "https://*.nytimes.com/?*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "48": "icons/letterNu48.png",
      "96": "icons/letterNu96.png"
    },
    "default_title": "NYTimesNoAutoplay"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.nytimes.com/",
        "https://www.nytimes.com/?*",
        "https://nytimes.com/",
        "https://nytimes.com/?*",
        "https://*.nytimes.com/",
        "https://*.nytimes.com/?*"
      ],
      "js": ["sites/nyt-betamax-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://www.nytimes.com/",
        "https://www.nytimes.com/?*",
        "https://nytimes.com/",
        "https://nytimes.com/?*",
        "https://*.nytimes.com/",
        "https://*.nytimes.com/?*"
      ],
      "js": ["sites/nyt-videos.js"],
      "run_at": "document_start"
    }
  ]
}
