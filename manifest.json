{
  "manifest_version": 3,
  "name": "NYTimesNoAutoplay",
  "version": "1.1.4",
  "description": "Stop video and carousel autoplay on NYTimes.com.",
  "browser_specific_settings": {
    "gecko": {
      "id": "nytimesnoautoplay@nunus.extension",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "128.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://nytimes.com/*",
    "https://*.nytimes.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    },
    "default_title": "NYTimes NoAutoplay"
  },
  "content_scripts": [
    {
      "matches": [
        "https://nytimes.com/*",
        "https://*.nytimes.com/*"
      ],
      "js": ["sites/nyt-betamax-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://nytimes.com/*",
        "https://*.nytimes.com/*"
      ],
      "js": ["sites/nyt-videos.js"],
      "run_at": "document_start"
    }
  ]
}
